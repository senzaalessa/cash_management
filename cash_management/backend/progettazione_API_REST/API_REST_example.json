    "auth": {

      "register": {
        "method": "POST",
        "url": "/auth/register",
        "description": "Registra un nuovo utente",
        "headers": {
          "Content-Type": "application/json"
        },
        "request_body": {
          "username": "Mario",
          "email": "mario@example.com",
          "password": "password123"
        },
        "response_success": {
          "success": true,
          "message": "Registrazione completata con successo",
          "data": {
            "token": "a3f8c2e1d9b047f6a2c8e5d1b0a7f3c9e2d8b1a4f7c0e3d6b9a2f5c8e1d4b7",
            "expires_at": "2026-05-15 14:30:00",
            "user": {
              "id": 1,
              "username": "Mario",
              "email": "mario@example.com"
            }
          }
        },
        "response_error_duplicate": {
          "success": false,
          "message": "Email o username già in uso"
        },
        "response_error_validation": {
          "success": false,
          "message": "Campi obbligatori mancanti: email, password"
        }
      },

      "login": {
        "method": "POST",
        "url": "/auth/login",
        "description": "Esegue il login e restituisce un Bearer Token",
        "headers": {
          "Content-Type": "application/json"
        },
        "request_body": {
          "email": "mario@example.com",
          "password": "password123"
        },
        "response_success": {
          "success": true,
          "message": "Login effettuato con successo",
          "data": {
            "token": "a3f8c2e1d9b047f6a2c8e5d1b0a7f3c9e2d8b1a4f7c0e3d6b9a2f5c8e1d4b7",
            "expires_at": "2026-05-15 14:30:00",
            "user": {
              "id": 1,
              "username": "Mario",
              "email": "mario@example.com"
            }
          }
        },
        "response_error": {
          "success": false,
          "message": "Credenziali non valide"
        }
      },

      "logout": {
        "method": "POST",
        "url": "/auth/logout",
        "description": "[AUTH] Invalida il token corrente",
        "headers": {
          "Content-Type": "application/json",
