        },
        "request_body": null,
        "response_success": {
          "success": true,
          "message": "Logout effettuato con successo"
        }
      },

      "me": {
        "method": "GET",
        "url": "/auth/me",
        "description": "[AUTH] Restituisce i dati dell'utente autenticato",
        "headers": {
          "Authorization": "Bearer a3f8c2e1d9b047f6a2c8e5d1b0a7f3c9e2d8b1a4f7c0e3d6b9a2f5c8e1d4b7"
        },
        "request_body": null,
        "response_success": {
          "success": true,
          "message": "Operazione completata",
          "data": {
            "id": 1,
            "username": "Mario",
            "email": "mario@example.com"
          }
        },
        "response_error_unauthorized": {
          "success": false,
